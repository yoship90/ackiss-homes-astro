---
import "../styles/global.css";
import playfairUrl from "@fontsource/playfair-display/files/playfair-display-latin-700-normal.woff2?url";
import interUrl from "@fontsource/inter/files/inter-latin-400-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ackiss Homes — Virginia Beach Real Estate",
  description = "Buying, selling, or investing in Virginia Beach and Hampton Roads? Ackiss Homes brings local expertise, integrity, and a client-first approach to every transaction.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon-package/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon-package/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-package/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-package/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon-package/site.webmanifest" />
    <link rel="preload" href={playfairUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interUrl} as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <div class="motion-safe:animate-page-reveal origin-top will-change-[transform,opacity] [backface-visibility:hidden]">
      <slot />
    </div>
  <script>
    requestAnimationFrame(() => window.scrollTo({ top: 0, behavior: "smooth" }));
    window.addEventListener("load", () => {
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("in-view"); observer.unobserve(e.target); } }),
        { threshold: 0.15 }
      );
      document.querySelectorAll(".sr").forEach(el => observer.observe(el));
    });
  </script>
  </body>
</html>
