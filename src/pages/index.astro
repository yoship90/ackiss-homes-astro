---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.svelte";
import Hero from "../components/Hero.svelte";
import Team from "../components/Team.astro";
import Services from "../components/Services.astro";
import PropertyInquiry from "../components/PropertyInquiry.svelte";
import PaymentCalculator from "../components/PaymentCalculator.svelte";
import Testimonials from "../components/Testimonials.svelte";
import SocialFeed from "../components/SocialFeed.astro";
import Contact from "../components/Contact.svelte";
import Footer from "../components/Footer.astro";
import StickyCTA from "../components/StickyCTA.astro";
import SectionDivider from "../components/SectionDivider.astro";

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://ackiss-homes-astro.vercel.app";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "RealEstateAgent",
      "@id": `${siteUrl}/#business`,
      name: "Ackiss Homes",
      url: siteUrl,
      logo: `${siteUrl}/logo-full-v2-optimized.svg`,
      description:
        "Buying, selling, or investing in Virginia Beach and Hampton Roads? Ackiss Homes brings local expertise, integrity, and a client-first approach to every transaction.",
      address: {
        "@type": "PostalAddress",
        streetAddress: "2135 General Booth Blvd, Suite 146",
        addressLocality: "Virginia Beach",
        addressRegion: "VA",
        postalCode: "23454",
        addressCountry: "US",
      },
      areaServed: [
        "Virginia Beach, VA",
        "Norfolk, VA",
        "Chesapeake, VA",
        "Suffolk, VA",
        "Portsmouth, VA",
        "Newport News, VA",
        "Hampton, VA",
        "Yorktown, VA",
        "Williamsburg, VA",
        "Gloucester, VA",
      ],
      sameAs: [
        "https://www.facebook.com/profile.php?id=100090275910543",
        "https://www.instagram.com/ackisshomes/",
        "https://www.google.com/maps/place/Ackiss+Homes+%7C+Triumph+Realty/@36.9928558,-76.6938425,10z/data=!3m1!4b1!4m6!3m5!1s0x45c72597d4c7fd19:0x8212763d7516ef5e!8m2!3d36.992763!4d-76.3642165!16s%2Fg%2F11z11c87vw",
      ],
      employee: [
        { "@id": `${siteUrl}/#amanda` },
        { "@id": `${siteUrl}/#jeremy` },
      ],
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#amanda`,
      name: "Amanda Ackiss",
      jobTitle: "Real Estate Agent",
      worksFor: { "@id": `${siteUrl}/#business` },
      sameAs: "https://www.zillow.com/profile/amanda5867",
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#jeremy`,
      name: "Jeremy Ackiss",
      jobTitle: "Real Estate Agent",
      worksFor: { "@id": `${siteUrl}/#business` },
      sameAs: "https://www.zillow.com/profile/jeremy2621",
    },
  ],
};
---

<Base jsonLd={jsonLd}>
  <Header client:load />
  <StickyCTA />
  <div class="motion-safe:animate-page-reveal origin-top">
    <main>
      <Hero client:load />
      <Team />
      <SectionDivider from="dark-900" to="dark-800" />
      <Services />
      <SectionDivider from="dark-800" to="dark-900" />
      <PropertyInquiry client:load />
      <PaymentCalculator client:visible />
      <SectionDivider from="dark-900" to="dark-800" />
      <Testimonials client:visible />
      <SocialFeed />
      <SectionDivider from="dark-800" to="dark-900" />
      <Contact client:load />
    </main>
    <Footer />
  </div>

</Base>
